# Believe Chops API (Express backend). Defaults to http://localhost:4000 if unset.
# On Vercel: set this to your deployed backend URL in Project → Settings → Environment Variables.
VITE_API_URL=http://localhost:4000

# Public URL of this React app (no trailing slash).
# On Vercel: set to your Vercel deployment URL, e.g. https://believechops.vercel.app
# VITE_SITE_URL=https://believechops.vercel.app
